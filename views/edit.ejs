<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Baby-Site</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="min-h-screen bg-zinc-900" >
    <div class="flex flex-col justify-center items-center gap-20 m-10">
        <div class="border-2 border-neutral-600 rounded-xl p-5 min-w-6/10 flex flex-col justify-center items-center gap-10">
            <h1 class="text-mauve-500 font-bold text-lg">Edit Your Post here...</h1>
            <form  class="flex items-start" action="/edit/<%=post._id %>" method="post">
                    <textarea name="post" id="postInput" placeholder="Create a post.."
                    class=" bg-transparent h-auto min-h-[470px] border-stone-500 border-2 rounded-xl text-zinc-400 outline-none p-3 md:w-[500px] resize-none" ><%= post.content%></textarea>

                    <button class="text-stone-100 border-2 rounded-lg border-neutral-200 font-bold p-2 bg-mist-700 cursor-pointer hover:bg-mauve-700 hover:text-olive-300 hover:rounded-xl transition ease-in 300 ml-10" >Update</button>
            </form>
        </div>
    </div>
    <script>
        const tx = document.getElementById('postInput');
    
        tx.addEventListener("input", function () {
            this.style.height = "auto";
            this.style.height = this.scrollHeight + "px";
        });
    </script>
</body>
</html>