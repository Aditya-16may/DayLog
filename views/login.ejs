<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Baby-Site</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="min-h-screen bg-zinc-900" >
    <div class="flex flex-col justify-center items-center gap-20 m-10">
        <h1 class="text-stone-100 border-2 rounded-xl border-neutral-200 font-bold p-2">Hello Baby</h1>
        <div class="border-2 border-neutral-600 rounded-xl p-5 min-w-4/10">
            <form method="post" action="/login" class="flex flex-col justify-center items-center gap-10">
                <div class="flex gap-5 justify-center items-center">
                    <p class=" text-center text-stone-200 w-[100px]">Email : </p>
                    <input type="email" placeholder="Email" name="email" class="border-2 border-stone-200 rounded-lg text-zince-200 outline-none bg-zinc-500 p-2" required>
                </div>
                <div class="flex gap-5 justify-center items-center">
                    <p class="text-stone-200 w-[100px] text-center">Password : </p>
                    <input type="password" placeholder="Password" name="password" class="border-2 border-stone-200 rounded-lg text-zince-200 outline-none bg-zinc-500 p-2" required>
                </div>
                <button class="text-stone-100 border-2 rounded-xs border-neutral-200 font-bold p-2 bg-neutral-500 cursor-pointer hover:bg-stone-500 hover:text-olive-800 hover:rounded-xl transition ease-in 300" value="Create Account">Login</button>
        </form>
        </div>
        
    </div>
</body>
</html>